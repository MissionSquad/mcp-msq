# MissionSquad API key used when hidden extra arg "apiKey" is not provided.
MSQ_API_KEY=

# Base API URL for v1 endpoints.
MSQ_BASE_URL=https://agents.missionsquad.ai/v1

# HTTP timeout for MissionSquad API requests.
MSQ_HTTP_TIMEOUT_MS=30000

# Default upper bound for GET /files/:id/content tool responses.
MSQ_DEFAULT_FILE_CONTENT_MAX_BYTES=1048576
