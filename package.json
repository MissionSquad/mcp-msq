{
  "name": "@missionsquad/mcp-msq",
  "version": "0.4.1",
  "description": "MCP server interface for the MissionSquad API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "mcp-msq": "./dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist build",
    "build": "yarn clean && tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "inspect": "fastmcp inspect src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "yarn build",
    "prepublishOnly": "yarn test && yarn build",
    "format": "npx prettier --check .",
    "format:write": "npx prettier --write ."
  },
  "keywords": [
    "mcp",
    "missionsquad",
    "agent",
    "ai",
    "llm",
    "api"
  ],
  "author": "Mission Squad AI <jayson@missionsquad.ai>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@missionsquad/fastmcp": "^1.1.3",
    "dotenv": "^16.4.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
